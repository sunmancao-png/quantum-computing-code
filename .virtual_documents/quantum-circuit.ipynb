from qiskit import QuantumCircuit
from qiskit.primitives import StatevectorSampler

qc = QuantumCircuit(2) # Initializing a quantum circuit with two qubits
qc.h(0) # Add an X-gate to qubit 0
qc.cx(0, 1) # Add a cx-gate to qubit 1 based on qubit 0
qc.measure_all() # Measures all the qubits

sampler = StatevectorSampler()
result = sampler.run([qc], shots=1024).result() # Take 1024 samples of quantum circuit
print(result[0].data.meas.get_counts())


import matplotlib.pyplot as plt
from qiskit.visualization import plot_histogram

counts = result[0].data.meas.get_counts()
plot_histogram(counts) # Plots the frequency of measurement results 00 and 11



